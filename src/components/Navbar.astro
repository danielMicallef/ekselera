---
import content from '../i18n/en.json';

const { logo, links, cta } = content.navbar;
---

<div class="fixed top-0 left-0 right-0 z-50 border-b border-base-200 bg-base-100/90 backdrop-blur">
  <div class="mx-auto flex h-20 max-w-6xl items-center justify-between gap-8 px-4">
  <div class="flex items-center gap-4">
    <div class="dropdown lg:hidden">
      <div tabindex="0" role="button" aria-label="Open navigation menu" class="btn btn-ghost lg:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
        </svg>
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] w-52 rounded-box bg-base-100 p-2 shadow">
        {links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
        <li><a href={cta.href} class="text-primary font-semibold">{cta.label}</a></li>
      </ul>
    </div>
    <a href="/" class="btn btn-ghost text-xl font-bold tracking-tight normal-case" aria-label="Ekselera home">
      {logo}
      <span class="text-primary">.</span>
    </a>
  </div>

  <div class="flex items-center gap-4">
    <ul class="hidden items-center gap-8 px-1 lg:flex">
      {links.map((link) => (
        <li><a class="text-sm font-medium text-base-content/75 hover:text-base-content" href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <a href="https://ziffa.io" class="btn btn-outline rounded-full border-base-300 px-5 hidden sm:inline-flex" target="_blank" rel="noreferrer">Ziffa ↗</a>
    <a href={cta.href} class="btn btn-primary rounded-full px-6 shadow-xl shadow-primary/20">{cta.label}</a>
  </div>
  </div>
</div>
