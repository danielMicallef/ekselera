---
import Layout from '../layouts/Layout.astro';
import IndustryIcon from '../components/IndustryIcon.astro';
import { Image } from 'astro:assets';
import andrew from "../assets/andrew.jpg";
import daniel from "../assets/daniel.webp";
import ziffaIcon from "../assets/ziffa-icon.png";

const title = "Ekselera — Turn Unstructured Data Into Decisions You Trust";
const canonicalOneLiner = "Ekselera takes unstructured information and turns it into reliable, decision-making information.";
const description = canonicalOneLiner;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://ekselera.com/#organization",
      name: "Ekselera Ventures",
      alternateName: "Ekselera",
      url: "https://ekselera.com/",
      logo: "https://ekselera.com/logo.png",
      description: canonicalOneLiner,
      vatID: "MT32680130",
      foundingLocation: "Malta",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Palm Court BLK A, Triq it-Torri, Flat 4, Xlendi",
        addressLocality: "Munxar",
        postalCode: "XLN1320",
        addressCountry: "MT"
      },
      areaServed: "MT",
      email: "info@ekselera.com",
      sameAs: [
        "https://ziffa.io/",
        "https://www.linkedin.com/company/ekselera/"
      ],
      founder: [
        {
          "@type": "Person",
          name: "Andrew Cassar Overend",
          jobTitle: "Founder & CEO",
          description: "Economist turned entrepreneur. Former Chief Economist at Malta's Ministry of Finance and Head of Investments at Malta's National Development and Social Fund. MSc Economics, Durham."
        },
        {
          "@type": "Person",
          name: "Daniel Micallef",
          jobTitle: "Co-founder & CTO",
          description: "Full-stack engineer with over a decade across fintech, gaming and edge AI."
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://ekselera.com/#website",
      url: "https://ekselera.com/",
      name: "Ekselera",
      publisher: { "@id": "https://ekselera.com/#organization" },
      inLanguage: "en"
    },
    {
      "@type": "ProfessionalService",
      name: "Ekselera — unstructured data to decision-grade information",
      url: "https://ekselera.com/",
      provider: { "@id": "https://ekselera.com/#organization" },
      areaServed: "MT",
      serviceType: "AI document & data automation, intelligent document processing",
      description: "Ekselera reads documents, images, video and scattered records, checks the content, and turns it into reliable information organisations can base decisions on — built into the systems they already use."
    },
    {
      "@type": "FAQPage",
      "@id": "https://ekselera.com/#faq",
      mainEntity: [
        {
          "@type": "Question",
          name: "What does Ekselera do?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Ekselera turns unstructured data — documents, images, video and scattered records — into reliable, decision-grade information. We read it, check it's correct, and deliver it inside the systems your team already uses."
          }
        },
        {
          "@type": "Question",
          name: "How is this different from OCR or a general-purpose AI tool?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Most tools stop at digitising — turning a document into text. That's the easy part, and it's where errors hide. Ekselera goes further: we extract what actually matters and make it trustworthy enough to act on. Most tools give you data; we give you decisions you can trust."
          }
        },
        {
          "@type": "Question",
          name: "Do we have to replace our existing systems?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "No. There's no migration. Ekselera works on top of the tools you already run — a layer on top, not a replacement. The decisions stay yours."
          }
        },
        {
          "@type": "Question",
          name: "Which industries is Ekselera built for?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Any sector where being wrong is expensive: government and public bodies, logistics and shipping, legal and notarial, aviation, real estate, and accounting firms and CSPs. Our flagship product, Ziffa, serves Maltese accounting firms and Corporate Service Providers."
          }
        }
      ]
    }
  ]
};

const problemCards = [
  {
    title: "Data is everywhere.",
    body: "Emails, PDFs, scans, photos, video, spreadsheets, paper. Different sources, no consistency — and someone has to make sense of all of it by hand."
  },
  {
    title: "Making it usable takes real effort.",
    body: "Reading, analysing, retyping, cross-checking, documenting — hours of skilled time spent just turning raw input into something you can act on."
  },
  {
    title: "And as you grow, it only gets heavier.",
    body: "The work scales with volume. The more you take on, the more there is to process — and the more your decisions depend on getting it right."
  }
];

const capabilities = [
  {
    title: "Meaning, not just data.",
    body: "We extract what actually matters and turn it into clear information you can base decisions on — the hard part, and the part most tools skip."
  },
  {
    title: "Analyse anything.",
    body: "Documents, images, video, scanned paper, scattered records — any format, any channel. Even a shoebox of receipts or a folder of phone photos."
  },
  {
    title: "Built on your rules.",
    body: "Your industry's regulations, formats and workflow, configured in — so what comes out fits your world, not a generic template."
  },
  {
    title: "Works inside your existing systems.",
    body: "We plug the information into the tools you already run — a layer on top, not a replacement."
  }
];

const industries = [
  {
    icon: "government",
    title: "Government & public bodies",
    body: "Applications in hundreds of formats — automatically vetted and processed, so officers decide faster and more consistently."
  },
  {
    icon: "logistics",
    title: "Logistics & shipping",
    body: "Bills of lading, customs paperwork, delivery notes, manifests — read and reconciled with a complete audit trail."
  },
  {
    icon: "legal",
    title: "Legal & notarial",
    body: "Case files, contracts, deeds, due-diligence packs — the clauses, dates and facts that matter, surfaced. Less manual searching, more judgement."
  },
  {
    icon: "aviation",
    title: "Aviation",
    body: "Manifests, load plans, ULD and maintenance records — turned into live operational data, so loading, utilisation and turnaround is based on facts, not guesswork."
  },
  {
    icon: "manufacturing",
    title: "Manufacturing",
    body: "Work orders, job cards, machine logs, quality and supplier reports — turned into clear operational information, so you cut waste, tighten scheduling and keep every line moving."
  },
  {
    icon: "real-estate",
    title: "Real estate",
    body: "Listings, tenancy agreements, lease expiries, permits, location and listing data — the paperwork behind every deal made clean and usable, so transactions move faster."
  },
  {
    icon: "accounting",
    title: "Accounting & CSPs",
    body: "Invoices, bank statements, IDs, MBR and FIAU documents — collected, checked and filed automatically into the firm's own storage.",
    featured: true
  }
];

const regularIndustries = industries.filter((industry) => !industry.featured);
const featuredIndustry = industries.find((industry) => industry.featured);

const faqs = [
  {
    question: "What does Ekselera do?",
    answer: "Ekselera turns unstructured data — documents, images, video and scattered records — into reliable, decision-grade information. We read it, check it's correct, and deliver it inside the systems your team already uses."
  },
  {
    question: "How is this different from OCR or a general-purpose AI tool?",
    answer: "Most tools stop at digitising — turning a document into text. That's the easy part, and it's where errors hide. Ekselera goes further: we extract what actually matters and make it trustworthy enough to act on. Most tools give you data; we give you decisions you can trust."
  },
  {
    question: "Do we have to replace our existing systems?",
    answer: "No. There's no migration. Ekselera works on top of the tools you already run — a layer on top, not a replacement. The decisions stay yours."
  },
  {
    question: "Which industries is Ekselera built for?",
    answer: "Any sector where being wrong is expensive: government and public bodies, logistics and shipping, legal and notarial, aviation, real estate, and accounting firms and CSPs. Our flagship product, Ziffa, serves Maltese accounting firms and Corporate Service Providers."
  }
];
---

<Layout title={title} description={description} canonical="https://ekselera.com/" jsonLd={jsonLd}>
  <section class="pt-48 pb-20 text-center lg:pt-56 lg:pb-28">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-4xl">
        <h1 class="mx-auto max-w-3xl text-5xl font-bold leading-[0.98] tracking-[-0.035em] text-base-content sm:text-6xl lg:text-7xl">
          Turn information into decisions you can trust.
        </h1>
        <p class="mx-auto mt-8 max-w-3xl text-lg leading-8 text-base-content/70 sm:text-2xl sm:leading-9">
          We help organizations transform unstructured noise into structured, actionable intelligence.  
        </p>

        <div class="promise-row">
          <div class="promise-item">
            <span class="promise-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2v4a2 2 0 0 0 2 2h4" />
                <path d="M16 13H8" />
                <path d="M16 17H8" />
                <path d="M10 9H8" />
                <path d="M20 10v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8l6 6Z" />
              </svg>
            </span>
            <div>
              <p class="font-semibold">Read anything</p>
              <p class="text-sm text-base-content/60">Documents, images, video, records</p>
            </div>
          </div>
          <div class="promise-item">
            <span class="promise-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5" />
              </svg>
            </span>
            <div>
              <p class="font-semibold">Check every detail</p>
              <p class="text-sm text-base-content/60">Confirmed correct, not guessed</p>
            </div>
          </div>
          <div class="promise-item">
            <span class="promise-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m22 2-7 20-4-9-9-4Z" />
                <path d="M22 2 11 13" />
              </svg>
            </span>
            <div>
              <p class="font-semibold">Deliver</p>
              <p class="text-sm text-base-content/60">Information you can act on</p>
            </div>
          </div>
          <div class="promise-item">
            <span class="promise-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
            </span>
            <div>
              <p class="font-semibold">Act with confidence</p>
              <p class="text-sm text-base-content/60">Decisions backed by facts</p>
            </div>
          </div>
        </div>

        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="mailto:info@ekselera.com?subject=Ekselera%20—%20let's%20talk" class="hero-btn hero-btn-primary">Reach out <span aria-hidden="true">→</span></a>
          <a href="#ziffa" class="hero-btn hero-btn-secondary">See Ziffa, our flagship product</a>
        </div>
        <p class="mt-4 text-sm text-base-content/60">Decisions based on facts, not guesses. Reach out to see what's possible.</p>
      </div>
    </div>
  </section>

  <section id="problem" class="bg-base-200 py-20 lg:py-28">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <p class="eyebrow">The problem</p>
        <h2 class="section-title problem-title">
          <span>You have too much information.</span>
          <strong>You have too little to act with.</strong>
        </h2>
        <p class="section-lead">
          Every organisation runs on processes, documents, images and records. The hard part isn't getting them — it's turning them into something you can act on. That work is slow, manual, and easy to underestimate.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {problemCards.map((card) => (
          <article class="landing-card">
            <h3 class="text-xl font-bold">{card.title}</h3>
            <p class="mt-3 text-base-content/70">{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="solution" class="bg-neutral py-20 text-neutral-content lg:py-28">
    <div class="container mx-auto px-4">
      <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <p class="eyebrow text-blue-300">What we do</p>
          <h2 class="section-title text-white">We turn unstructured data into decisions you can trust.</h2>
          <p class="mt-6 text-lg leading-8 text-neutral-content/75">
            Most tools stop at digitising — they turn a document into text and call it done. That's the easy part, and it leaves you with more data, not more clarity.
          </p>
          <p class="mt-4 text-lg leading-8 text-neutral-content/75">
            Ekselera goes further. We take the unstructured data your organisation runs on — documents, images, video, scattered records — and turn it into clear, meaningful information you can base decisions on. Not just digitised. Understood.
          </p>
        </div>
        <div class="rounded-lg border border-white/10 bg-white/5 p-8 shadow-2xl">
          <blockquote class="text-xl font-bold leading-tight text-white sm:text-xl">
            Most tools give you data. <span class="text-blue-300">We give you decisions you can trust.</span>
          </blockquote>
          <div class="mt-8 grid gap-4">
            <div class="flex gap-3">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-blue-300/10 text-blue-300" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z" />
                  <path d="m2 12 8.58 3.91a2 2 0 0 0 1.66 0L22 12" />
                  <path d="m2 17 8.58 3.91a2 2 0 0 0 1.66 0L22 17" />
                </svg>
              </span>
              <p><strong class="text-white">No migration.</strong> <span class="text-neutral-content/70">We build on top of the systems you already use.</span></p>
            </div>
            <div class="flex gap-3">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-blue-300/10 text-blue-300" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="21" x2="14" y1="4" y2="4" />
                  <line x1="10" x2="3" y1="4" y2="4" />
                  <line x1="21" x2="12" y1="12" y2="12" />
                  <line x1="8" x2="3" y1="12" y2="12" />
                  <line x1="21" x2="16" y1="20" y2="20" />
                  <line x1="12" x2="3" y1="20" y2="20" />
                  <line x1="14" x2="14" y1="2" y2="6" />
                  <line x1="8" x2="8" y1="10" y2="14" />
                  <line x1="16" x2="16" y1="18" y2="22" />
                </svg>
              </span>
              <p><strong class="text-white">Built on your rules.</strong> <span class="text-neutral-content/70">Configured to your industry and workflow — not a one-size-fits-all tool.</span></p>
            </div>
            <div class="flex gap-3">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-blue-300/10 text-blue-300" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
              </span>
              <p><strong class="text-white">You stay in control.</strong> <span class="text-neutral-content/70">We make the information trustworthy. The decisions stay yours.</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="capabilities" class="py-20 lg:py-28">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <p class="eyebrow">What the engine does</p>
        <h2 class="section-title">Everything that turns data into decisions you can trust.</h2>
        <p class="section-lead">One engine, configured to your world — ranked by what matters most.</p>
      </div>

      <div class="mt-12 grid overflow-hidden rounded-lg border border-base-300 bg-base-100 md:grid-cols-2">
        {capabilities.map((capability, index) => (
          <article class="capability-card">
            <span class="number-badge">{index + 1}</span>
            <div>
              <h3 class="text-xl font-bold">{capability.title}</h3>
              <p class="mt-2 text-base-content/70">{capability.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="how" class="bg-base-200 py-20 lg:py-28">
    <div class="container mx-auto px-4">
      <p class="eyebrow">How it works</p>
      <h2 class="section-title">Simple to start, built to last.</h2>

      <div class="mt-12 grid gap-8 md:grid-cols-3">
        <article class="step-card">
          <p class="step-label">STEP 01</p>
          <h3 class="mt-3 text-xl font-bold">Show us the data.</h3>
          <p class="mt-3 text-base-content/70">We look at where your information comes in, what you do with it today, and where the hours and the risk are leaking.</p>
        </article>
        <article class="step-card">
          <p class="step-label">STEP 02</p>
          <h3 class="mt-3 text-xl font-bold">We build the system.</h3>
          <p class="mt-3 text-base-content/70">We configure the engine to read, make sense of, and deliver your specific information — inside the tools you already use, on your rules.</p>
        </article>
        <article class="step-card">
          <p class="step-label">STEP 03</p>
          <h3 class="mt-3 text-xl font-bold">You decide with confidence — and we stay.</h3>
          <p class="mt-3 text-base-content/70">Reliable information, ready when you need it. White-glove, not a hand-off: we stay on for support as your work changes.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="industries" class="py-20 lg:py-28">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <p class="eyebrow">Who it's for</p>
        <h2 class="section-title">Built for work where being wrong is expensive.</h2>
        <p class="section-lead">One engine, wherever scattered information drives decisions that have to be right.</p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {regularIndustries.map((industry) => (
          <article class="landing-card">
            <div class="flex gap-4">
              <IndustryIcon icon={industry.icon} />
              <div>
                <h3 class="text-lg font-bold">{industry.title}</h3>
                <p class="mt-3 text-base-content/70">{industry.body}</p>
              </div>
            </div>
          </article>
        ))}
      </div>

      {featuredIndustry && (
        <div class="mt-8 flex justify-center">
          <article class="landing-card w-full max-w-xl border-primary bg-primary/5 text-center">
            <IndustryIcon icon={featuredIndustry.icon} class="mx-auto" />
            <h3 class="mt-4 text-lg font-bold">{featuredIndustry.title}</h3>
            <p class="mt-3 text-base-content/70">{featuredIndustry.body}</p>
            <a class="mt-4 inline-flex font-semibold text-primary" href="#ziffa">This is Ziffa, our flagship →</a>
          </article>
        </div>
      )}
    </div>
  </section>

  <section id="ziffa" class="bg-neutral py-20 text-neutral-content lg:py-28">
    <div class="container mx-auto px-4">
      <div class="grid gap-12 lg:grid-cols-[1fr_0.9fr] lg:items-center">
        <div>
          <p class="eyebrow text-blue-300">Proven in the wild</p>
          <h2 class="section-title text-white">Proven in the wild: Ziffa.</h2>
          <p class="mt-6 text-lg leading-8 text-neutral-content/75">
            Ziffa is the engine built deep into one industry: document automation for Maltese accounting firms and Corporate Service Providers — a demanding, heavily regulated field. It collects, checks and files client documents straight into the firm's own SharePoint or Google Drive, and several practices are running it across hundreds of client entities today.
          </p>
          <div class="mt-8 grid gap-4 sm:grid-cols-3">
            <div class="stat-card"><strong>140+</strong><span>Maltese document types</span></div>
            <div class="stat-card"><strong>100s</strong><span>of client entities live today</span></div>
            <div class="stat-card"><strong>0</strong><span>migration — runs in your own storage</span></div>
          </div>
        </div>
        <div class="rounded-lg bg-white p-8 text-base-content shadow-2xl">
          <div class="flex items-center gap-4">
            <span class="inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-neutral p-2">
              <Image src={ziffaIcon} alt="Ziffa" class="size-full translate-y-px rounded-full object-contain" width={40} height={40} />
            </span>
            <div>
              <h3 class="text-3xl font-bold text-[#C8962E]">Ziffa</h3>
              <p class="text-base-content/60">Document automation for Maltese accounting firms & CSPs.</p>
            </div>
          </div>
          <ul class="mt-8 space-y-4 text-base-content/80">
            <li>✓ Collects and chases client documents</li>
            <li>✓ Checks, renames and files automatically</li>
            <li>✓ Inside your own SharePoint or Google Drive</li>
          </ul>
          <a href="https://ziffa.io/" class="btn btn-primary mt-8" target="_blank" rel="noreferrer">See how Ziffa works →</a>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="py-20 lg:py-28">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <p class="eyebrow">Who we are</p>
        <h2 class="section-title">Economics meets engineering.</h2>
        <p class="section-lead">
          Ekselera was built by an economist and an engineer who've spent their careers inside regulated, document-heavy operations — government, fintech, manufacturing and professional services.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        <article class="landing-card">
          <Image src={andrew} alt="Andrew Cassar Overend, Co-Founder and CEO of Ekselera" class="h-16 w-16 rounded-full object-cover" />
          <h3 class="mt-5 text-xl font-bold">Andrew Cassar Overend</h3>
          <p class="mt-1 font-semibold text-primary">Co-Founder & CEO, Strategy & Product</p>
          <p class="mt-4 text-base-content/70">
